}

.galeria img{
    width:100%;
    border-radius:8px;
}

.produtos{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
}

.produto{
    background:#f8f8f8;
    padding:15px;
    border-left:5px solid #2e7d32;
}

footer{
    background:#1b5e20;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:40px;
}
</style>

